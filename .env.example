# Generic ARM64 build config template

MODE=local-x86
ACTION=build

SOURCE_TYPE=git
GIT_REPO=https://github.com/example/project.git
GIT_REF=main
LOCAL_SOURCE_DIR=
SOURCE_SUBDIR=.

BUILDER_IMAGE=maven:3.9.9-eclipse-temurin-21
BUILDER_APT_PACKAGES="git ca-certificates"
BUILDER_SETUP_CMD=:
BUILD_CMD="mvn -DskipTests package"

ARTIFACT_PATH=target/app.tar.gz
ARTIFACT_MODE=archive

RUNTIME_IMAGE=eclipse-temurin:21-jre-jammy
RUNTIME_APT_PACKAGES="ca-certificates curl"
RUNTIME_SETUP_CMD=:
APP_DEST=/opt/app
START_COMMAND="java -jar /opt/app/app.jar"
EXPOSE_PORTS=8012

IMAGE_NAME=custom-arm64:local
CONTAINER_NAME=custom-arm64
PLATFORM=linux/arm64
HOST_PORT=8012
CONTAINER_PORT=8012
RUN_ENV_VARS=

BUILDER_NAME=multiarch-generic
INSTALL_BINFMT=1
BUILDER_FORCE_RECREATE=0
LOCAL_OUTPUT=--load
LOCAL_PROGRESS=auto

REMOTE_HOST=
REMOTE_PORT=22
REMOTE_USER=
REMOTE_WORKDIR=/tmp/generic-arm64-build
REMOTE_IMAGE_NAME=custom-arm64:local
REMOTE_PROGRESS=plain
REMOTE_BUILD_CMD="docker build"
SYNC_TOOL=scp
