# kkFileView 5.0.0 full demo config
# Upstream version reference verified from project README/release notes on 2026-05-18.

MODE=local-arm
ACTION=build

SOURCE_TYPE=git
GIT_REPO=https://github.com/kekingcn/kkFileView.git
GIT_REF=v5.0.0
SOURCE_SUBDIR=.

BUILDER_IMAGE=maven:3.9.9-eclipse-temurin-21
BUILDER_APT_PACKAGES="git ca-certificates"
BUILDER_SETUP_CMD=:
BUILD_CMD="mvn -pl server -am -DskipTests clean package"

ARTIFACT_PATH="server/target/kkFileView-*.tar.gz"
ARTIFACT_MODE=archive

RUNTIME_IMAGE=eclipse-temurin:21-jre
RUNTIME_APT_PACKAGES="ca-certificates fontconfig libreoffice-writer libreoffice-calc libreoffice-impress libreoffice-draw libreoffice-java-common fonts-wqy-zenhei"
RUNTIME_SETUP_CMD="rm -rf /usr/lib/libreoffice/share/gallery /usr/lib/libreoffice/share/template /var/tmp/* /tmp/*"
APP_DEST=/opt
ARCHIVE_STRIP_COMPONENTS=0
START_COMMAND="export KKFILEVIEW_BIN_FOLDER=/opt/kkFileView-5.0.0/bin KK_CACHE_TYPE=jdk; java -Dfile.encoding=UTF-8 -Dspring.config.location=/opt/kkFileView-5.0.0/config/application.properties -jar /opt/kkFileView-5.0.0/bin/kkFileView-5.0.0.jar"
EXPOSE_PORTS=8012

IMAGE_NAME=kkfileview-arm64:v5.0.0
CONTAINER_NAME=kkfileview-arm64
PLATFORM=linux/arm64
HOST_PORT=8012
CONTAINER_PORT=8012
RUN_ENV_VARS="KK_TRUST_HOST=*,KKFILEVIEW_BIN_FOLDER=/opt/kkFileView-5.0.0/bin,KK_CACHE_TYPE=jdk"

LOCAL_PROGRESS=auto

REMOTE_HOST=
REMOTE_PORT=22
REMOTE_USER=
REMOTE_WORKDIR=/tmp/kkfileview-arm64-build
REMOTE_IMAGE_NAME=kkfileview-arm64:v5.0.0
REMOTE_PROGRESS=plain
REMOTE_BUILD_CMD="docker build"
SYNC_TOOL=scp
